{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "MONGODB_URI": "@MONGODB_URI",
    "GEMINI_API_KEY": "@GEMINI_API_KEY",
    "SMTP_HOST": "@SMTP_HOST",
    "SMTP_PORT": "@SMTP_PORT",
    "SMTP_USER": "@SMTP_USER",
    "SMTP_PASS": "@SMTP_PASS",
    "SMTP_FROM": "@SMTP_FROM"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
